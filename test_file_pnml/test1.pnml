<?xml version="1.0" encoding="UTF-8"?>
<pnml>
  <net id="net2" type="http://www.pnml.org/version-2009/grammar/ptnet">
    <page id="page1">

      <!-- Places -->
      <place id="p1">
        <name><text>Start</text></name>
        <initialMarking><text>1</text></initialMarking>
      </place>

      <place id="p2">
        <name><text>Buffer 1</text></name>
        <initialMarking><text>0</text></initialMarking>
      </place>

      <place id="p3">
        <name><text>Buffer 2</text></name>
        <initialMarking><text>0</text></initialMarking>
      </place>

      <place id="p4">
        <name><text>Finish</text></name>
        <initialMarking><text>0</text></initialMarking>
      </place>

      <!-- Transitions -->
      <transition id="t1">
        <name><text>Step 1</text></name>
      </transition>

      <transition id="t2">
        <name><text>Step 2</text></name>
      </transition>

      <transition id="t3">
        <name><text>Join</text></name>
      </transition>

      <!-- Arcs -->
      <arc id="a1" source="p1" target="t1"/>
      <arc id="a2" source="t1" target="p2"/>
      <arc id="a3" source="t1" target="p3"/>
      <arc id="a4" source="p2" target="t2"/>
      <arc id="a5" source="p3" target="t2"/>
      <arc id="a6" source="t2" target="p4"/>
      <arc id="a7" source="p4" target="t3"/>
      <arc id="a8" source="t3" target="p1"/>

    </page>
  </net>
</pnml>
